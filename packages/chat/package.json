{
  "name": "@yonus-a/chat",
  "version": "0.1.0",
  "type": "module",
  "description": "A themeable, data-agnostic Vue 3 chat module with adapter pattern for real-time messaging",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": ">=3.3.0",
    "pinia": ">=2.1.0"
  },
  "dependencies": {
    "@vueuse/core": "^14.0.0",
    "@tanstack/vue-virtual": "^3.13.0",
    "@phosphor-icons/vue": "^2.2.1"
  },
  "devDependencies": {
    "vue": "^3.5.0",
    "pinia": "^2.3.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "vue-tsc": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "vue",
    "chat",
    "messaging",
    "vue3",
    "pinia",
    "themeable"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yonus-a/chat"
  }
}
