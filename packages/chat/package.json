{
  "name": "@behayand/chat",
  "version": "0.1.0",
  "description": "Reusable chat UI component with pluggable data adapter for Vue 3",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.3.0",
    "pinia": "^2.1.0 || ^3.0.0"
  },
  "dependencies": {
    "@phosphor-icons/vue": "^2.2.1",
    "@vueuse/core": "^14.0.0",
    "@tanstack/vue-virtual": "^3.13.0"
  },
  "devDependencies": {
    "vue": "^3.5.31",
    "pinia": "^3.0.4",
    "vue-tsc": "^2.2.0",
    "vite": "^6.3.5",
    "typescript": "^5.8.3",
    "@vitejs/plugin-vue": "^5.2.4",
    "tailwindcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2"
  },
  "license": "MIT"
}
